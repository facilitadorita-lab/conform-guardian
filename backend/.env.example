# Frontend público — configurar no Lovable
VITE_SUPABASE_URL=https://PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY

# GitHub Actions — cadastrar como GitHub Secrets, nunca neste arquivo
SUPABASE_ACCESS_TOKEN=
SUPABASE_PROJECT_ID=
SUPABASE_DB_PASSWORD=

# Edge Functions — cadastrar com `supabase secrets set`
CRON_SECRET=
EMAIL_WEBHOOK_URL=
ALLOWED_ORIGIN=https://seu-dominio.com.br
INVITE_REDIRECT_URL=https://seu-dominio.com.br/redefinir-senha

# Pagamentos — Asaas
ASAAS_API_KEY=
ASAAS_ENV=sandbox
ASAAS_WEBHOOK_TOKEN=

# Assistente IA seguro
# Opcional. Sem chave, o modo gratuito usa respostas estruturadas sem ler anexos.
AI_PROVIDER=structured
